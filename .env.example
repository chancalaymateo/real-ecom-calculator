# Copiar este archivo a .env.local y completar con los valores reales
# NUNCA subir .env.local al repositorio

# ── Supabase (Dashboard → Project Settings → API) ─────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin panel ────────────────────────────────────────────────
ADMIN_PASSWORD=cambiar_esto

# ── Generador de Clips (Kie.ai) ────────────────────────────────
# Opcional: si la cargás acá, la herramienta la usa por defecto.
# Si la dejás vacía, cada usuario pega su propia key en la UI.
KIE_API_KEY=
